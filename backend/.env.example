# Server
PORT=3000
NODE_ENV=development

# Postgres (matches docker-compose)
DATABASE_URL=postgresql://monii:monii@localhost:5432/monii?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-prod-please-use-a-long-random-string
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
JWT_DEVICE_TTL=31536000

# Heartbeat / presence
HEARTBEAT_INTERVAL_SECONDS=75
HEARTBEAT_MISS_GRACE=2

# Command spine
COMMAND_TTL_SECONDS=300

# FCM (path to a service-account JSON, or leave blank to use the no-op stub in dev)
FCM_SERVICE_ACCOUNT_PATH=
